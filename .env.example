# EconOS environment variables
#
# The committed snapshot pipeline uses public, keyless endpoints and requires
# no credentials. The variables below are optional and only needed for
# higher-rate-limit or richer API access in future pipeline work.

# Optional: FRED API key (https://fred.stlouisfed.org/docs/api/api_key.html)
# FRED_API_KEY=

# Optional: BLS Public Data API v2 key (https://www.bls.gov/developers/)
# BLS_API_KEY=

# Optional: BEA API key (https://apps.bea.gov/api/signup/)
# BEA_API_KEY=

# Optional: Census API key (https://api.census.gov/data/key_signup.html)
# CENSUS_API_KEY=
